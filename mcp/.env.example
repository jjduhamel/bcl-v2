# Copy to mcp/.env and fill in. mcp/.env is gitignored.

# Deployed Lobby proxy address. For local dev, take this from
# broadcast/DeployLobby.s.sol/31337/run-latest.json after `yarn deploy:lobby`.
LOBBY_ADDRESS=0x

# Optional. Defaults to http://127.0.0.1:8545 (anvil).
# RPC_URL=http://127.0.0.1:8545

# --- Dev mode (default) ---
# Server signs writes itself with this key. Required when NODE_ENV is unset.
# Must be UNSET when NODE_ENV=production (startup aborts otherwise).
PRIVATE_KEY=0x

# --- Prod mode ---
# Set NODE_ENV=production to disable server-side signing. In prod the server
# holds no key; every write tool round 1 returns a digest the caller signs
# externally and echoes back in round 2. Multi-tenant: each caller supplies
# their own `from` (writes) or `player` (reads).
# NODE_ENV=production
