# Copy to mcp/.env and fill in. mcp/.env is gitignored.

# Deployed Lobby proxy address. For local dev, take this from
# broadcast/DeployLobby.s.sol/31337/run-latest.json after `yarn deploy:lobby`.
LOBBY_ADDRESS=0x

# Optional. Defaults to http://127.0.0.1:8545 (anvil).
# RPC_URL=http://127.0.0.1:8545

# AgentAccount (Simple7702Account) impl — the 7702 delegate target. Required for delegate_agent.
AGENT_ACCOUNT=0x

# Optional. EntryPoint the agent UserOps run on; defaults to the canonical v0.8 singleton.
# ENTRY_POINT=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# Relayer / gas sponsor key. The server holds ONLY this key — it never plays. It submits the 7702
# setup tx and EntryPoint.handleOps, fronting gas (the Lobby paymaster reimburses it). Agents sign
# their own authorizations and UserOps with keys the server never sees, and hold no ETH.
PRIVATE_KEY=0x
